TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
TELEGRAM_BOT_TOKEN=1234567890:replace-with-your-bot-token

# Optional paths/settings.
PYTDBOT_FILES_DIR=.tdlib
PYTDBOT_DB_KEY=change-me
PYTDBOT_TD_VERBOSITY=2
PYTDBOT_TD_LOG=tdlib.log
# PYTDBOT_TDJSON_LIB=/absolute/path/to/libtdjson.so

# Runtime controls. Settings are persisted by Telegram sender id.
BOT_SETTINGS_PATH=bot_settings.json
BOT_OUTPUT_DIR=encoded
MAX_JOBS_PER_USER=1
STALE_FILE_HOURS=24
